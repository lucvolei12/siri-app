<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover">
  <title>Siri App</title>
  <style>
    :root {
      --bg-gradient: radial-gradient(circle at 50% 30%, #1c1c1e 0%, #000000 100%);
      --card-bg: rgba(28, 28, 30, 0.7);
      --text-main: #ffffff;
      --text-muted: #8e8e93;
    }

    * {
      box-sizing: border-box;
      -webkit-tap-highlight-color: transparent;
    }

    body {
      background: var(--bg-gradient);
      color: var(--text-main);
      margin: 0;
      padding: 0;
      font-family: -apple-system, BlinkMacSystemFont, "SF Pro Display", "SF Pro Text", sans-serif;
      height: 100vh;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      overflow: hidden;
    }

    .header-spacer {
      height: calc(env(safe-area-inset-top, 20px) + 15px);
      width: 100%;
    }

    /* Container de mensagens */
    .chat-wrapper {
      flex: 1;
      overflow-y: auto;
      padding: 0 20px;
      display: flex;
      flex-direction: column;
      gap: 20px;
      scroll-behavior: smooth;
    }

    .chat-wrapper::-webkit-scrollbar {
      width: 0px;
    }

    /* Balão do Usuário */
    .user-bubble {
      align-self: flex-end;
      background: rgba(44, 44, 46, 0.6);
      padding: 12px 18px;
      border-radius: 20px;
      max-width: 80%;
      font-size: 16px;
      line-height: 1.4;
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      border: 1px solid rgba(255, 255, 255, 0.05);
      animation: fadeIn 0.3s ease-out;
    }

    /* Resposta do Siri App */
    .siri-response-container {
      align-self: flex-start;
      width: 100%;
      font-size: 16px;
      line-height: 1.5;
      color: #f5f5f7;
      animation: fadeIn 0.4s ease-out both;
    }

    /* Card de Conteúdo Estilo Apple */
    .apple-card {
      background: var(--card-bg);
      border-radius: 24px;
      overflow: hidden;
      margin-top: 12px;
      box-shadow: 0 8px 24px rgba(0, 0, 0, 0.4);
      border: 1px solid rgba(255, 255, 255, 0.08);
      backdrop-filter: blur(30px);
      -webkit-backdrop-filter: blur(30px);
    }

    .apple-card img {
      width: 100%;
      height: 180px;
      object-fit: cover;
      display: block;
    }

    .card-details {
      padding: 14px 16px;
    }

    .card-title {
      font-size: 15px;
      font-weight: 600;
      margin-bottom: 6px;
    }

    .badge {
      display: inline-block;
      background: rgba(255, 255, 255, 0.1);
      padding: 4px 8px;
      border-radius: 8px;
      font-size: 11px;
      color: var(--text-muted);
    }

    /* Indicador de Digitando */
    .typing-indicator {
      display: inline-flex;
      gap: 4px;
      padding: 8px 12px;
    }

    .typing-dot {
      width: 6px;
      height: 6px;
      background: var(--text-muted);
      border-radius: 50%;
      animation: bounce 1.4s infinite ease-in-out both;
    }
    .typing-dot:nth-child(2) { animation-delay: 0.2s; }
    .typing-dot:nth-child(3) { animation-delay: 0.4s; }

    /* Barra Inferior Liquid Glass */
    .bottom-area {
      padding: 12px 20px calc(env(safe-area-inset-bottom, 12px) + 8px) 20px;
      width: 100%;
    }

    .glass-input-bar {
      background: rgba(30, 30, 32, 0.6);
      border-radius: 28px;
      display: flex;
      align-items: center;
      padding: 4px 12px;
      border: 1px solid rgba(255, 255, 255, 0.1);
      backdrop-filter: blur(30px) saturate(180%);
      -webkit-backdrop-filter: blur(30px) saturate(180%);
      box-shadow: inset 0 1px 1px rgba(255, 255, 255, 0.1), 0 10px 25px rgba(0,0,0,0.3);
    }

    .bar-btn {
      background: transparent;
      border: none;
      color: #a1a1a6;
      font-size: 20px;
      cursor: pointer;
      padding: 8px;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .bar-btn:active {
      transform: scale(0.92);
    }

    .input-box {
      flex: 1;
      background: transparent;
      border: none;
      color: var(--text-main);
      font-size: 16px;
      padding: 10px 6px;
      outline: none;
    }

    .input-box::placeholder {
      color: #545456;
    }

    /* Brilho Cromático */
    .chroma-glow {
      height: 2.5px;
      width: 50%;
      margin: 6px auto 0 auto;
      background: linear-gradient(90deg, transparent, #00f0ff, #a400ff, #ff007f, transparent);
      filter: blur(2px);
      opacity: 0.7;
      border-radius: 50%;
      animation: pulse 2.5s infinite alternate ease-in-out;
    }

    @keyframes fadeIn { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: translateY(0); } }
    @keyframes bounce { 0%, 80%, 100% { transform: scale(0); } 40% { transform: scale(1); } }
    @keyframes pulse { 0% { width: 45%; opacity: 0.5; } 100% { width: 55%; opacity: 0.8; } }
  </style>
</head>
<body>

  <div class="header-spacer"></div>

  <div class="chat-wrapper" id="chat">
    <div class="user-bubble">Where is Apple headquarters?</div>
    <div class="siri-response-container">
      Apple Park, also known as Apple Campus 2, is the corporate headquarters of Apple Inc., located in Cupertino, California, United States. It was opened to employees in April 2017.
      <div class="apple-card">
        <img src="https://images.unsplash.com/photo-1563986768609-322da13575f3?auto=format&fit=crop&w=800&q=80" alt="Apple Park">
        <div class="card-details">
          <div class="card-title">The Apple Park campus</div>
          <span class="badge">Wikipedia +2</span>
        </div>
      </div>
    </div>
  </div>

  <div class="bottom-area">
    <div class="glass-input-bar">
      <button class="bar-btn">📎</button>
      <input type="text" class="input-box" id="userInput" placeholder="Ask Siri App" onkeypress="checkKey(event)">
      <button class="bar-btn" onclick="sendMessage()">✍️</button>
    </div>
    <div class="chroma-glow"></div>
  </div>

  <script>
    const chat = document.getElementById('chat');
    const userInput = document.getElementById('userInput');

    function checkKey(e) {
      if (e.key === 'Enter') sendMessage();
    }

    function sendMessage() {
      const text = userInput.value.trim();
      if (!text) return;

      userInput.value = '';

      const uBubble = document.createElement('div');
      uBubble.className = 'user-bubble';
      uBubble.innerText = text;
      chat.appendChild(uBubble);
      chat.scrollTop = chat.scrollHeight;

      const typingDiv = document.createElement('div');
      typingDiv.className = 'typing-indicator';
      typingDiv.innerHTML = '<div class="typing-dot"></div><div class="typing-dot"></div><div class="typing-dot"></div>';
      chat.appendChild(typingDiv);
      chat.scrollTop = chat.scrollHeight;

      setTimeout(() => {
        typingDiv.remove();
        
        const sContainer = document.createElement('div');
        sContainer.className = 'siri-response-container';
        
        if(text.toLowerCase().includes('olá') || text.toLowerCase().includes('oi')) {
          sContainer.innerText = "Olá! Eu sou o assistente do seu Siri App. Como posso ajudar você hoje?";
        } else if(text.toLowerCase().includes('criador') || text.toLowerCase().includes('quem fez')) {
          sContainer.innerText = "Este aplicativo foi feito por lucvolei12 no GitHub, projetado com uma interface líquida premium!";
        } else {
          sContainer.innerText = `Siri App processou o comando: "${text}". Conexão ativa e funcionando de forma perfeita!`;
        }

        chat.appendChild(sContainer);
        chat.scrollTop = chat.scrollHeight;
      }, 1200);
    }
  </script>
</body>
</html>

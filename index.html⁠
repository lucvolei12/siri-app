<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover">
  <title>Siri App</title>
  <style>
    :root {
      --bg-gradient: radial-gradient(circle at 50% 30%, #1c1c1e 0%, #000000 100%);
      --card-bg: rgba(28, 28, 30, 0.75);
      --text-main: #ffffff;
      --text-muted: #8e8e93;
    }

    * {
      box-sizing: border-box;
      -webkit-tap-highlight-color: transparent;
    }

    body {
      background: var(--bg-gradient);
      color: var(--text-main);
      margin: 0;
      padding: 0;
      font-family: -apple-system, BlinkMacSystemFont, "SF Pro Display", "SF Pro Text", sans-serif;
      height: 100vh;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      overflow: hidden;
    }

    .header-spacer {
      height: calc(env(safe-area-inset-top, 20px) + 15px);
      width: 100%;
    }

    /* Container de Mensagens */
    .chat-wrapper {
      flex: 1;
      overflow-y: auto;
      padding: 0 24px;
      display: flex;
      flex-direction: column;
      gap: 24px;
      scroll-behavior: smooth;
    }

    .chat-wrapper::-webkit-scrollbar {
      width: 0px;
    }

    /* Balão do Usuário estilo Apple */
    .user-bubble {
      align-self: flex-end;
      background: rgba(58, 58, 60, 0.6);
      padding: 14px 20px;
      border-radius: 22px;
      max-width: 80%;
      font-size: 16px;
      line-height: 1.4;
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      border: 1px solid rgba(255, 255, 255, 0.05);
      animation: fadeIn 0.3s cubic-bezier(0.25, 1, 0.5, 1);
    }

    /* Resposta da IA / Siri App */
    .siri-response-container {
      align-self: flex-start;
      width: 100%;
      font-size: 17px;
      line-height: 1.5;
      color: #e8e8ed;
      animation: fadeIn 0.4s cubic-bezier(0.25, 1, 0.5, 1) both;
    }

    /* Card Multimídia Premium */
    .apple-card {
      background: var(--card-bg);
      border-radius: 26px;
      overflow: hidden;
      margin-top: 14px;
      box-shadow: 0 12px 30px rgba(0, 0, 0, 0.5);
      border: 1px solid rgba(255, 255, 255, 0.08);
      backdrop-filter: blur(30px);
      -webkit-backdrop-filter: blur(30px);
    }

    .apple-card img {
      width: 100%;
      height: 200px;
      object-fit: cover;
      display: block;
      border-bottom: 1px solid rgba(255, 255, 255, 0.03);
    }

    .card-details {
      padding: 16px 18px;
    }

    .card-title {
      font-size: 16px;
      font-weight: 600;
      margin: 0 0 6px 0;
    }

    .badge {
      display: inline-flex;
      background: rgba(255, 255, 255, 0.08);
      padding: 5px 10px;
      border-radius: 10px;
      font-size: 12px;
      color: var(--text-muted);
      font-weight: 500;
    }

    /* Indicador de Digitando Recriado */
    .typing-indicator {
      display: inline-flex;
      gap: 6px;
      padding: 12px 16px;
      align-self: flex-start;
    }

    .typing-dot {
      width: 7px;
      height: 7px;
      background: #86868b;
      border-radius: 50%;
      animation: bounce 1.4s infinite ease-in-out both;
    }
    .typing-dot:nth-child(2) { animation-delay: 0.2s; }
    .typing-dot:nth-child(3) { animation-delay: 0.4s; }

    /* Painel Inferior Flutuante Liquid Glass */
    .bottom-area {
      padding: 16px 24px calc(env(safe-area-inset-bottom, 16px) + 12px) 24px;
      width: 100%;
    }

    .glass-input-bar {
      background: rgba(30, 30, 32, 0.65);
      border-radius: 30px;
      display: flex;
      align-items: center;
      padding: 6px 16px;
      border: 1px solid rgba(255, 255, 255, 0.1);
      backdrop-filter: blur(35px) saturate(190%);
      -webkit-backdrop-filter: blur(35px) saturate(190%);
      box-shadow: 
        inset 0 1px 2px rgba(255, 255, 255, 0.15),
        0 8px 32px rgba(0, 0, 0, 0.4);
    }

    .bar-btn {
      background: transparent;
      border: none;
      color: #a1a1a6;
      font-size: 22px;
      cursor: pointer;
      padding: 8px;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: color 0.2s, transform 0.2s;
    }

    .bar-btn:active {
      transform: scale(0.9);
      color: var(--text-main);
    }

    .input-box {
      flex: 1;
      background: transparent;
      border: none;
      color: var(--text-main);
      font-size: 17px;
      padding: 12px 10px;
      outline: none;
      letter-spacing: -0.2px;
    }

    .input-box::placeholder {
      color: #636366;
    }

    /* Brilho de Luz Inferior Avançado */
    .chroma-glow {
      height: 3px;
      width: 45%;
      margin: 8px auto 0 auto;
      background: linear-gradient(90deg, 
        transparent 0%, 
        #00f0ff 25%, 
        #a400ff 50%, 
        #ff007f 75%, 
        transparent 100__
      );
      filter: blur(2.5px);
      opacity: 0.75;
      border-radius: 50%;
      animation: pulse 3s infinite alternate ease-in-out;
    }

    @keyframes fadeIn { from { opacity: 0; transform: translateY(12px); } to { opacity: 1; transform: translateY(0); } }
    @keyframes bounce { 0%, 80%, 100% { transform: scale(0); } 40% { transform: scale(1); } }
    @keyframes pulse { 0% { width: 40%; opacity: 0.6; filter: blur(2px); } 100% { width: 55%; opacity: 0.9; filter: blur(3.5px); } }
  </style>
</head>
<body>

  <div class="header-spacer"></div>

  <div class="chat-wrapper" id="chat">
    <div class="user-bubble">Where is Apple headquarters?</div>
    <div class="siri-response-container">
      Apple Park, also known as Apple Campus 2, is the corporate headquarters of Apple Inc., located in Cupertino, California, United States. It was opened to employees in April 2017.
      <div class="apple-card">
        <img src="https://images.unsplash.com/photo-1563986768609-322da13575f3?auto=format&fit=crop&w=800&q=80" alt="Apple Park">
        <div class="card-details">
          <div class="card-title">The Apple Park campus</div>
          <span class="badge">Wikipedia +2</span>
        </div>
      </div>
    </div>
  </div>

  <div class="bottom-area">
    <div class="glass-input-bar">
      <button class="bar-btn">📎</button>
      <input type="text" class="input-box" id="userInput" placeholder="Ask Siri App" onkeypress="checkKey(event)">
      <button class="bar-btn" onclick="sendMessage()">🎙️</button>
    </div>
    <div class="chroma-glow"></div>
  </div>

  <script>
    const chat = document.getElementById('chat');
    const userInput = document.getElementById('userInput');

    function checkKey(e) {
      if (e.key === 'Enter') sendMessage();
    }

    function sendMessage() {
      const text = userInput.value.trim();
      if (!text) return;

      userInput.value = '';

      // Mensagem do usuário
      const uBubble = document.createElement('div');
      uBubble.className = 'user-bubble';
      uBubble.innerText = text;
      chat.appendChild(uBubble);
      chat.scrollTop = chat.scrollHeight;

      // Adiciona indicador de digitação nativo
      const typingDiv = document.createElement('div');
      typingDiv.className = 'typing-indicator';
      typingDiv.innerHTML = '<div class="typing-dot"></div><div class="typing-dot"></div><div class="typing-dot"></div>';
      chat.appendChild(typingDiv);
      chat.scrollTop = chat.scrollHeight;

      // Respostas inteligentes integradas com o espírito Gemini
      setTimeout(() => {
        typingDiv.remove();
        
        const sContainer = document.createElement('div');
        sContainer.className = 'siri-response-container';
        
        const formatText = text.toLowerCase();
        
        if (formatText.includes('olá') || formatText.includes('oi')) {
          sContainer.innerText = "Olá! Eu sou o assistente inteligente do seu Siri App, totalmente calibrado com o ecossistema Gemini. Em que posso te ajudar hoje?";
        } else if (formatText.includes('criador') || formatText.includes('quem fez')) {
          sContainer.innerText = "Este Siri App espetacular foi desenvolvido por lucvolei12 e hospedado diretamente no GitHub Pages!";
        } else if (formatText.includes('teste') || formatText.includes('funciona')) {
          sContainer.innerText = "Teste concluído com sucesso! O sistema de inputs, as animações e os filtros de desfoque estão operando com 100% de estabilidade.";
        } else {
          sContainer.innerText = `Siri App processou a requisição e ativou os núcleos computacionais para analisar: "${text}". Tudo pronto por aqui!`;
        }

        chat.appendChild(sContainer);
        chat.scrollTop = chat.scrollHeight;
      }, 1100);
    }
  </script>
</body>
</html>
